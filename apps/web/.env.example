NEXTAUTH_URL=http://localhost:3000
# Generate with `openssl rand -base64 32` and use the same value on the api side.
NEXTAUTH_SECRET=replace-me-with-a-32-byte-random-string

GOOGLE_CLIENT_ID=123
GOOGLE_CLIENT_SECRET=123

NEXT_PUBLIC_API_URL=http://localhost:4000
NEST_URL=http://localhost:4000

# Plausible Analytics — cookieless, GDPR-friendly. Paste the full
# tracker URL from your Plausible dashboard → Site settings →
# Installation (looks like https://plausible.io/js/pa-XXXXXXX.js —
# the site identifier is baked into the URL). Empty/unset disables
# analytics entirely (the script tag is omitted), which is what you
# want in local dev so dev pageviews don't pollute prod stats.
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=
