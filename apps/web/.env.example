NEXTAUTH_URL=http://localhost:3000
# Generate with `openssl rand -base64 32` and use the same value on the api side.
NEXTAUTH_SECRET=replace-me-with-a-32-byte-random-string

GOOGLE_CLIENT_ID=123
GOOGLE_CLIENT_SECRET=123

NEXT_PUBLIC_API_URL=http://localhost:4000
NEST_URL=http://localhost:4000

# Plausible Analytics — cookieless, GDPR-friendly. Set to your live
# domain(s) once you've created the property at plausible.io. Multiple
# domains comma-separated. Empty/unset disables analytics entirely
# (the script tag is omitted), which is what you want in local dev.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
