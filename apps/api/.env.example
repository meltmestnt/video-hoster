PORT=4000
# Generate with `openssl rand -base64 32` and use the same value on the web side.
NEXTAUTH_SECRET=replace-me-with-a-32-byte-random-string
DATABASE_URL=postgres://app:app@localhost:5432/app
WEB_ORIGIN=http://localhost:3000

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=123
AWS_SECRET_ACCESS_KEY=123
S3_BUCKET=123

# Web Push (subscriber/like notifications). Generate the keypair with
#   npx web-push generate-vapid-keys
# and paste both halves below. Leave empty to disable push entirely; the
# in-site bell keeps working either way.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@vidsandgifs.xyz

# Discord bot. Create an application + bot at
#   https://discord.com/developers/applications
# DISCORD_CLIENT_ID is the Application ID (not the bot user id).
# DISCORD_BOT_TOKEN is the bot's token from the Bot tab.
# Both unset → bot is disabled cleanly (the rest of the API still boots).
# DISCORD_DEV_GUILD_ID scopes slash commands to one guild for instant dev
# iteration; leave unset in prod for global registration.
DISCORD_CLIENT_ID=
DISCORD_BOT_TOKEN=
DISCORD_DEV_GUILD_ID=
