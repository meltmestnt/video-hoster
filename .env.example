# ───────────── shared ─────────────
# Same secret for both web (signs) and api (verifies). Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-random-32+-byte-string

# ───────────── apps/web ─────────────
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:4000
NEST_URL=http://localhost:4000

# ───────────── apps/api ─────────────
PORT=4000
DATABASE_URL=postgres://app:app@localhost:5432/app
WEB_ORIGIN=http://localhost:3000
# Comma-separated emails granted the admin role on every login. Adding or
# removing an email here promotes/demotes the user on their next request —
# no DB editing required.
ADMIN_EMAILS=

# AWS S3 (real bucket)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ───────────── mail ─────────────
# Picks the transport: "resend" (recommended), "smtp" (Mailtrap, etc.), or "ses".
# If sending fails, sign-up returns an error — the user is NOT created.
MAIL_TRANSPORT=resend
# For Resend without a verified domain you can use onboarding@resend.dev
MAIL_FROM=onboarding@resend.dev

# Resend (recommended for prod): grab API key from https://resend.com/api-keys
RESEND_API_KEY=

# Mailtrap (dev): grab credentials from
# https://mailtrap.io → Sandbox → Inbox → SMTP Settings → Node.js / Nodemailer.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

# ───────────── docker-compose ─────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
