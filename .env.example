# ───────────── shared ─────────────
# Same secret for both web (signs) and api (verifies). Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-random-32+-byte-string

# ───────────── apps/web ─────────────
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:4000
NEST_URL=http://localhost:4000

# Search engine site verification. Paste the bare token (no <meta> wrapper)
# from each platform's onboarding flow. The framework emits the meta tag on
# every page when the var is set; leave empty otherwise.
#   Google:  https://search.google.com/search-console → Add property →
#            URL prefix → HTML tag method → copy the `content` value.
#   Bing:    https://www.bing.com/webmasters → Add site → Meta tag method.
#   Yandex:  https://webmaster.yandex.com → Add site → Meta tag.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX). Get one at
# https://analytics.google.com → Admin → Create property → Web stream →
# copy the Measurement ID. Leave empty in dev/preview so test traffic
# doesn't pollute the prod property. The NEXT_PUBLIC_ prefix is required
# because the script tag is emitted client-side.
NEXT_PUBLIC_GA_ID=

# ───────────── apps/api ─────────────
PORT=4000
DATABASE_URL=postgres://app:app@localhost:5432/app
WEB_ORIGIN=http://localhost:3000
# Public origin where the API is served. The media proxy embeds this in
# every signed media URL so videos/images load from your domain instead
# of S3. Defaults to http://localhost:<PORT> when unset.
API_PUBLIC_URL=http://localhost:4000
# Comma-separated emails granted the admin role on every login. Adding or
# removing an email here promotes/demotes the user on their next request —
# no DB editing required.
ADMIN_EMAILS=

# ───────────── LemonSqueezy (subscriptions) ─────────────
# Create a store at https://app.lemonsqueezy.com, then:
#   Settings → API → New API key
LEMONSQUEEZY_API_KEY=
# Numeric store ID, found at Settings → General.
LEMONSQUEEZY_STORE_ID=
# Create a Product → "Pro" with a recurring price, then copy the Variant ID
# (numeric, on the variant detail page).
LEMONSQUEEZY_PRO_VARIANT_ID=
# Settings → Webhooks → New webhook → URL: <WEB_ORIGIN>/webhook/lemonsqueezy
# Subscribe to all subscription_* events. Copy the signing secret here.
LEMONSQUEEZY_WEBHOOK_SECRET=

# AWS S3 (real bucket)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ───────────── mail ─────────────
# Picks the transport: "resend" (recommended), "smtp" (Mailtrap, etc.), or "ses".
# If sending fails, sign-up returns an error — the user is NOT created.
MAIL_TRANSPORT=resend
# For Resend without a verified domain you can use onboarding@resend.dev
MAIL_FROM=onboarding@resend.dev

# Resend (recommended for prod): grab API key from https://resend.com/api-keys
RESEND_API_KEY=

# Mailtrap (dev): grab credentials from
# https://mailtrap.io → Sandbox → Inbox → SMTP Settings → Node.js / Nodemailer.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=

# ───────────── docker-compose ─────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
